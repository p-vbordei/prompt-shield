{
  "name": "@p-vbordei/prompt-shield",
  "version": "0.1.0",
  "description": "Detect prompt-injection patterns in untrusted text. Pattern-based scanner with severity levels, custom rules, and code-fence stripping.",
  "keywords": [
    "llm",
    "prompt-injection",
    "security",
    "guardrails",
    "ai-safety"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "author": {
    "name": "Vlad Bordei",
    "email": "bordeivlad@gmail.com",
    "url": "https://github.com/p-vbordei"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/p-vbordei/prompt-shield.git"
  },
  "bugs": {
    "url": "https://github.com/p-vbordei/prompt-shield/issues"
  },
  "homepage": "https://github.com/p-vbordei/prompt-shield#readme",
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  }
}
